# ── Build artifacts ───────────────────────────────────────────────────────────
# All meson builds go in the top-level build/ directory.
# Per-project standalone builds also use build/ inside each project.
**/build*/

**/bin/
**/lib/
# Vendored upstream subprojects ship their library sources in `lib/`.
# Allow those back in.
!subprojects/*/lib/
!subprojects/*/lib/**

# Compiled objects (shouldn't appear outside build/ but just in case)
*.o
*.a
*.so
*.dylib
*.dll
*.lib
*.exe

# ── IDE / Editor ─────────────────────────────────────────────────────────────
**/.cache/
**/.vscode/
**/.idea/
*.swp
*.swo
*~
*.kate-swp
.clangd/
**/.clangd/
compile_commands.json
**/compile_commands.json
**/.claude/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini

# ── VCS ──────────────────────────────────────────────────────────────────────
# jujutsu internals (the .jj dirs)
**/.jj/
.workspaces/

# Python
**/__pycache__/
*.pyc

# Unicode data cache + generated tables
.unicode_cache/
src/unicode/generated/

# Coverage / profiling
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata

# Docker SDK tarballs + per-run extracted logs
docker/sdk/
docker/_linux_logs/

# Vendored subproject sources (cloned at build time)
/subprojects/mir/
/subprojects/ncc/

AGENTS.md
.inspector-gadget/
plans/
# Sub-directories of test/data/resharp/ that hold large generated corpora;
# the test/data/resharp/tests/*.toml fixtures the regex_resharp test reads
# are tracked.
test/data/resharp/haystacks/
test/data/resharp/regexes/
.aider*

# Created by chalk-tool when oracle round-trip tests run.
chalk-reports.jsonl
