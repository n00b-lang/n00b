[constants]
toolchain = '/usr'

[binaries]
c = toolchain / 'bin/x86_64-w64-mingw32-gcc'
ar = toolchain / 'bin/x86_64-w64-mingw32-ar'
strip = toolchain / 'bin/x86_64-w64-mingw32-strip'
windres = toolchain / 'bin/x86_64-w64-mingw32-windres'

[properties]
needs_exe_wrapper = true

[host_machine]
system = 'windows'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
