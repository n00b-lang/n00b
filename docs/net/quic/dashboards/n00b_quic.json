{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Phase 5 § 5.12 — starter dashboard for the n00b QUIC + RPC runtime.  Pairs with the metric set registered by `n00b_quic_endpoint_new(.metrics_registry=...)`, `n00b_quic_audit_attach_metrics`, and `n00b_rpc_server_attach_metrics`.",
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "Channel opens / sec (by kind)",
      "targets": [
        {
          "expr": "rate(n00b_quic_chan_opens_total[1m])",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "Channels active (by kind)",
      "targets": [
        {
          "expr": "n00b_quic_chan_active",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "title": "RPC calls / sec (by service.method, status)",
      "targets": [
        {
          "expr": "sum by (service, method, status) (rate(n00b_quic_rpc_calls_total[1m]))",
          "legendFormat": "{{service}}.{{method}} → {{status}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "µs"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "title": "RPC call duration p50 / p99 (µs)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(n00b_quic_rpc_call_duration_us_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(n00b_quic_rpc_call_duration_us_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "title": "Audit allow / deny rate",
      "targets": [
        {
          "expr": "sum by (decision) (rate(n00b_quic_audit_events_total[1m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 604800},
              {"color": "green",  "value": 1209600}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 6,
      "title": "Cert expiry countdown (per endpoint)",
      "targets": [
        {
          "expr": "n00b_quic_cert_expiry_seconds",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "type": "stat"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["n00b", "quic", "phase5"],
