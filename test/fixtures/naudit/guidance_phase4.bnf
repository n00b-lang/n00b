@schema_version 1
@project n00b-audit-test-phase4
@description Phase 4 CLI regression fixture -- same shape as guidance_ok.bnf with the DF-C BNF fragment and DF-D violation_nt populated so the engine can drive end-to-end against fixture_null.c and fixture_nullptr.c without in-process struct injection.
@source_doc test/fixtures/audit/guidance_phase4.bnf
@dependencies

@rule n00b.s2_1.null
@title NULL -> nullptr
@section section 2.1
@violation_nt n00b_audit_v_null
@rationale C23 has nullptr; NULL is a legacy macro.
@bad int *p = NULL;
@good int *p = nullptr;
    return p == nullptr ? 0 : 1;
@guidance Replace NULL with nullptr in all expression positions.

<n00b_audit_v_null> ::= %"NULL"
rewrite {
    template: nullptr
    description: NULL → nullptr (C23).
}
<provided_identifier> ::= <n00b_audit_v_null>
