@schema_version 1
@project test_baseline
@description WP-011 baseline test workspace.
@source_doc test/fixtures/naudit/test_naudit_baseline.c
@dependencies
@extensions
    c: .c, .h

@rule n00b.s2_1.null
@title NULL -> nullptr
@section section 2.1
@language c
@violation_nt n00b_audit_v_null
@rationale C23 has nullptr.
@bad int *p = NULL;
@good int *p = nullptr;
@guidance Replace NULL with nullptr.

<n00b_audit_v_null> ::= %"NULL"
<provided_identifier> ::= <n00b_audit_v_null>
